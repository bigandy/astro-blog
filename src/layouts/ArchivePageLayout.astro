---
import BlogPostPreview from "@components/Blog/BlogPostPreview.astro";
import ArchiveNav from "@components/Global/ArchiveNav.astro";
import DefaultLayout from "@layouts/DefaultLayout.astro";
import type { CollectionEntry } from "astro:content";

const isBlog = Astro.props.page.url.current.includes('blog');

export type ArchivePageEntry = CollectionEntry<"weeknotes" | "blog" | "blog-fr" | "weeknotes" | "weeknotes-fr"> & { postIndex: number }

interface Props {
    collection: "weeknotes" | "blog" | "blog-fr" | "weeknotes" | "weeknotes-fr";
	page: {
		currentPage: number;
		data: Array<ArchivePageEntry>;
        url: {
            current: string;
        }
	};
}

const { page, collection } = Astro.props;
const title = `${isBlog ? "Blog" : "Weeknote"} Archive Page ${page.currentPage}`;
---

<DefaultLayout title={title}>
    <div class="top-nav">
        <ArchiveNav page={page} />
    </div>

    {
        page.data.map((post) => <BlogPostPreview post={post} postIndex={post.postIndex} collection={collection} /> )
    }

    <ArchiveNav page={page} />
</DefaultLayout>
<style>
    .top-nav {
        margin-block-end: 2em;
    }
</style>