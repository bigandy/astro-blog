{
	"extends": "astro/tsconfigs/strictest",
	"compilerOptions": {
		// "module": "esnext",
		// "target": "esnext",
		// "jsx": "react-jsx",
		"paths": {
			"@css/*": [
				"./src/css/*"
			],
			"@components/*": [
				"./src/components/*"
			],
			"@pages/*": [
				"./src/pages/*"
			],
			"@layouts/*": [
				"./src/layouts/*"
			],
			"@utils/*": [
				"./src/utils/*"
			]
		}
	}
}