{
	"name": "andrewhudson-dev-astro",
	"version": "2.0.0",
	"private": true,
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"build:check": "npm run build && npm run check",
		"preview": "astro preview",
		"update": "npx @astrojs/upgrade && npx npm-check-updates -u",
		"update:beta": "npx @astrojs/upgrade beta && npx npm-check-updates -u",
		"lint-format": "biome check --write",
		"create-post": "node ./script.mjs",
		"check": "astro check --noSync"
	},
	"dependencies": {
		"@astrojs/check": "0.9.8",
		"@astrojs/compiler-rs": "0.1.6",
		"@astrojs/mdx": "5.0.3",
		"@astrojs/react": "5.0.3",
		"@astrojs/rss": "4.0.18",
		"@astrojs/svelte": "8.0.4",
		"@lit-labs/preact-signals": "1.0.3",
		"@semantic-ui/astro-lit": "5.3.0",
		"astro": "6.1.5",
		"lightningcss": "1.32.0",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"svelte": "5.55.2",
		"typescript": "5.9.3"
	},
	"devDependencies": {
		"@11ty/eleventy-fetch": "5.1.2",
		"@biomejs/biome": "2.4.11",
		"@clack/prompts": "1.2.0",
		"@notionhq/client": "5.17.0",
		"@types/lodash": "4.17.24",
		"@types/markdown-it": "14.1.2",
		"@types/sanitize-html": "2.16.1",
		"execa": "9.6.1",
		"fs-extra": "11.3.4",
		"linkedom": "0.18.12",
		"markdown-it": "14.1.1",
