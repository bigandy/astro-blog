---
import BlogPostList from "@components/Blog/BlogPostList.astro";
import ForwardArrow from "@components/Global/ForwardArrow.astro";
import DefaultLayout from "@layouts/DefaultLayout.astro";

const title = "Weeknotes";
---

<DefaultLayout title={title}>
    <BlogPostList number={9} collection="weeknotes" />

    <ForwardArrow
        url="/weeknotes/2/"
        title="See more weeknotes"
        extraClass="forward-arrow"
    />
</DefaultLayout>

<style is:global>
    .forward-arrow {
        margin-block-start: --spacing(2);
    }
</style>
