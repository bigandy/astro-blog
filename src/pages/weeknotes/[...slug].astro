---
import { type CollectionEntry } from "astro:content";

import { getAllPosts } from "@components/Blog/utils/getAllPosts";
import SlugPageLayout from "@layouts/SlugPageLayout.astro";
export const prerender = true;

const collection = "weeknotes";

interface Props {
	post: CollectionEntry<typeof collection>;
	postIndex: number;
}

const { post, postIndex } = Astro.props;

export async function getStaticPaths() {
	const posts = await getAllPosts("weeknotes");

	return posts.map((post) => {
		return {
			params: { slug: post.id },
			props: {
				postIndex: post.postIndex,
				post,
			},
		};
	});
}
---
<SlugPageLayout postIndex={postIndex} collection={collection} post={post} />
