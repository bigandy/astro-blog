---
import { isProduction } from "@utils/isProduction";
import SpeculationRules from "./SpeculationRules.astro";
import css from "@css/global.css?raw";

interface Props {
	title: string;
	description?: string | undefined;
	useGlobalCSS?: boolean;
}

const descriptionFallback = "Senior Software Engineer looking for answers.";

const {
	title = descriptionFallback,
	description = descriptionFallback,
	useGlobalCSS = true
} = Astro.props;

---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/x-icon" href="/favicon.ico" />

{useGlobalCSS && (
    <style set:html={css}></style>
)}

<title>{title !== "" ? `${title} - ` : ""}Andrew JD Hudson</title>
<meta name="title" content={title !== "" ? title : descriptionFallback} />
<meta name="description" content={description} />

{isProduction && (
    <SpeculationRules />
)}

<meta name="theme-color" content="#ffcc00" />
<link rel="manifest" href="/manifest.json" />

<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />

<meta property="fediverse:creator" content="@bigandy@indieweb.social" />

<link
    rel="alternate"
    type="application/rss+xml"
    title={"Andrew JD Hudson - Senior Front-end Engineer"}
    href={new URL("rss.xml", Astro.site)}
/>
