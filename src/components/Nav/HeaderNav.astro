---
import SettingsToggler from "@components/CV/SettingsToggler.astro";
import ExternalLink from "@components/Global/ExternalLink.astro";

import { headerPages } from "./pages";
import { getNavClassName } from "./utils";

const requestPathname = Astro.url.pathname;

const locale = Astro.currentLocale ?? "en";

const { hidePhoto = false } = Astro.props;
const prefix = Astro.currentLocale !== "en" ? `/${Astro.currentLocale}` : "";
---
<nav class="layout wrapper">
  <ul class="layout-inner nav">
    {
      headerPages.map((entry) => {
        const className = getNavClassName(entry.url, requestPathname);
        const href = prefix + entry.url;

        return (
          <li>
            {entry.external ? (
              <ExternalLink href={entry.url}>{entry.title}</ExternalLink>
            ) : (
            <a class={className} href={href}>
              {(locale === 'fr' && entry.title['fr']) || entry.title.default}
            </a>
            )}
          </li>
        );
      })
    }
  </ul>
  {!hidePhoto && (
    <SettingsToggler
        src="/images/cv/andrew-profile.jpg"
        alt="Photo of Andrew JD Hudson"
        showThemeSwitcher
    />
  )}
</nav>

<style>
  .wrapper {
    display: grid;
    grid-template-columns: auto auto;
  }

  li {
    display: inline-grid;
    margin-inline-end: 1em;
  }

  a {
    border-block-end: 2px solid transparent;
  }

  a:hover,
  .active {
    border-bottom-color: var(--theme-accent);
  }

  ul {
    padding-inline-start: 0;
  }

  .language-switcher {
    margin-inline-start: auto;
  }

  :global(.settings-toggler) {
    translate: 0 -35%;
  }
</style>
