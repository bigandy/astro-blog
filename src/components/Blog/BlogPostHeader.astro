---
import PostNumber from "./PostNumber.astro";
import PublishDate from "./PublishDate.astro";

interface Props {
	date?: string | undefined;
	title: string;
	isPreview?: boolean;
	slug: string;
	viewTransitionName: string;
	postIndex?: number | undefined;
}

const {
	date,
	title,
	isPreview = false,
	slug,
	viewTransitionName,
	postIndex,
} = Astro.props;
---

<header
    class={`${isPreview ? "preview" : "post"}`}
    style={`--vt-header: vt-${viewTransitionName.replaceAll("/", "")}`}
>
    {
        isPreview ? (
            <a href={`/${slug}`}>
                <h2 class="title">{title}</h2>

                {date && <PublishDate date={date} class="publish-date" />}

                <PostNumber number={postIndex} isPost={!isPreview} />
            </a>
        ) : (
            <Fragment>
                <h1 class="title">{title}</h1>
                {date && (
                    <PublishDate date={date} class="publish-date" showLine />
                )}

                <PostNumber number={postIndex} isPost={!isPreview} />
            </Fragment>
        )
    }
</header>

<style>
    .preview {
        display: grid;
        grid-template-columns: 1fr auto;


        a {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 0;

            .title,
            .publish-date {
                grid-column-start: 1;
            }

            .post-number {
                grid-row: 1 / span 2;
                grid-column: 2;
            }
        }

        .title,
        .publish-date {
            margin: 0;
        }

        .publish-date {
            font-size: 1.25rem;
            color: var(--theme-text-lighter);
            font-weight: var(--f-body-weight);
            font-family: var(--header-font-family);
            line-height: 1.3;
            order: -1;
        }

        .title {
            font-size: 2.25rem;
            color: var(--theme-text);

            @media (max-width: 1050px) {
                padding-inline-end: 4rem;
            }
        }
    }

    /* BlogPost */
    .post {
        padding-block-end: --unit(1);

        & p,
        & li {
            margin-block-end: 1rem;
        }

        .publish-date {
            margin: 0;
        }

        .title {
            line-height: 1;
            text-wrap: pretty;
            border-bottom: 10px solid orangered;
        }
    }

    @container (inline-size > 1000px) {
        header {
            position: relative;
            view-transition-name: var(--vt-header);
        }
    }
</style>
