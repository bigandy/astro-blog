---
interface Props {
	skills: string[];
}
const { skills } = Astro.props;
---

<ul>
    {skills?.map((skill) => <li>{skill}</li>)}
</ul>

<style>
    ul {
        padding-inline-start: 0;
        line-height: 1;
    }

    li {
        display: inline-block;
        padding-inline-end: 0.25rem;
        margin-block-end: 0;
        padding-block-end: 0;

        &:not(:last-child)::after {
            content: "/";
            padding-inline-start: 0.25rem;
            color: var(--theme-accent);
        }
    }
</style>
