---
import CVLayout from "@layouts/CVLayout.astro";

// CV Specific Components

import EducationList from "@components/CV/EducationList.astro";
import PorfolioList from "@components/CV/PorfolioList.astro";
import RolesList from "@components/CV/RolesList.astro";
import SettingsToggler from "@components/CV/SettingsToggler.astro";
import SkillsList from "@components/CV/SkillsList.astro";
import SocialLinksList from "@components/CV/SocialLinksList.astro";

import "@css/cv-full-stack.css";

import {
	education,
	personalInformation,
	portfolioLinks,
	roles,
	skills,
	socialLinks,
} from "./content";

const overrideFullDates = false;

const summaryFullStack = `I am a senior software engineer with 14+ years of experience creating highly performant and usable
products, websites, desktop applications, and browser extensions using Node, PHP, JS, CSS, a Database via APIs`;

const personalInformationFullStack = {
	title: "Senior Full Stack Engineer",
};
---

<CVLayout
    title="CV Full Stack"
    bodyClass="full-stack"
    accent="#008cff"
>
    <header>
        <div class="contact h-card">
            <div>
                <h1 class="contact-name p-name">
                    <a href="/">{personalInformation.name}</a>
                </h1>
                <div class="meta">
                    <p class="contact-title">
                        <strong>{personalInformationFullStack.title}</strong>
                    </p>
                    <a href={`mailto:${personalInformation.email}`}
                        >{personalInformation.email}</a
                    >
                    <a href={`tel:${personalInformation.phone}`} class="tel"
                        >{personalInformation.phone}</a
                    >
                    <p class="p-locality">{personalInformation.location}</p>
                </div>
            </div>

            <SettingsToggler
                src="/images/cv/andrew-profile.jpg"
                alt="Photo of Andrew JD Hudson"
                dimension={70}
            />
        </div>
    </header>



    <section class="main-column">
        <section class="summary">
            <h2>Summary</h2>

            <p>
                {summaryFullStack}
            </p>
        </section>

        <section>
            <h2 id="experience">Experience</h2>

            <ol class="entrylist list--dashed" reversed>
                <RolesList
                    roles={roles}
                    overrideFullDates={overrideFullDates}
                />
            </ol>
        </section>


    </section>

    <aside>
        <section>
            <h2 id="skills">Skills</h2>

            <SkillsList skills={skills} />
        </section>


        <section>
            <h2 id="education">Education</h2>
            <ul class="list--dashed list--plain list--compact cv-education-list">
                <EducationList education={education} />
            </ul>
        </section>

        <section>
            <h2 id="relevant-experience">Selected Portfolio</h2>

            <PorfolioList hideDash links={portfolioLinks} />
        </section>

        <section>
            <h2 id="online-links">Online Links</h2>

            <ul class="cv-social list--dashed list--compact">
                <SocialLinksList links={socialLinks} />
            </ul>
        </section>
    </aside>

    <div class="hide-print switch-portfolio-link">
        <a href="/cv/with-sidebar/">Switch to version of CV with sidebar</a>
    </div>
</CVLayout>
