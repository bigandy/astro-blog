---
import Canvas from "@components/Global/Canvas.astro";
import DemoLayout from "@layouts/DemoLayout.astro";

const title = "Canvas 2 - drawing circles";
---

<DemoLayout title={title}>
  <div class="container">
    <Canvas />
  </div>
</DemoLayout>

<script>
  const canvas = document.getElementById("canvas") as HTMLCanvasElement;

  const { width, height } = canvas;

  const ctx = canvas.getContext("2d")!;



  const drawCircle = (x: number, y: number, size: number, color = "red") => {
    ctx.beginPath();
    ctx.arc(x, y, size, 0, 2 * Math.PI);
    ctx.fillStyle = color;
    ctx.fill();
    ctx.closePath();
  };

  // Make a circle
  // const middle = (height / 2, width / 2);

  // x, y, radius, start angle (in radians), end angle (in radians)
  drawCircle(width / 2, height / 2, 100, "black");
  drawCircle(width / 3, height / 3, 20, "red");
  drawCircle(width / 4, height / 4, 40, "blue");
</script>
