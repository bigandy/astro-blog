{
	"extends": "astro/tsconfigs/strictest",
	"compilerOptions": {
		"paths": {
			"@css/*": [
				"./src/css/*"
			],
			"@components/*": [
				"./src/components/*"
			],
			"@pages/*": [
				"./src/pages/*"
			],
			"@layouts/*": [
				"./src/layouts/*"
			],
			"@utils/*": [
				"./src/utils/*"
			]
		}
	}
}