{
	"extends": "astro/tsconfigs/strictest",
	// "exclude": [
	// 	"./script/*/*.mjs"
	// ],
	"include": [
		"src/**/*"
	],
	"compilerOptions": {
		"paths": {
			"@css/*": [
				"./src/css/*"
			],
			"@components/*": [
				"./src/components/*"
			],
			"@pages/*": [
				"./src/pages/*"
			],
			"@layouts/*": [
				"./src/layouts/*"
			],
			"@utils/*": [
				"./src/utils/*"
			]
		}
	}
}