{
	"name": "andrewhudson-dev-astro",
	"version": "2.0.0",
	"private": true,
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"build:check": "npm run build && npm run check",
		"preview": "astro preview",
		"update": "npx @astrojs/upgrade && npx npm-check-updates -u && npm i",
		"update:beta": "npx @astrojs/upgrade beta && npx npm-check-updates -u && npm i",
		"lint-format": "biome check --write",
		"lint:css": "stylelint \"**/*.css\"",
		"lint:css:fix": "stylelint \"**/*.css\" --fix",
		"create-post": "node ./script.mjs",
		"check": "astro check --noSync",
		"test": "vitest"
	},
	"dependencies": {
		"@astrojs/markdown-satteri": "0.3.2",
		"@astrojs/mdx": "7.0.0",
		"@astrojs/react": "6.0.0",
		"@astrojs/rss": "4.0.18",
		"@astrojs/svelte": "9.0.0",
		"@awesome.me/astro-lit": "5.0.4",
		"@expressive-code/plugin-collapsible-sections": "0.44.0",
		"@lit-labs/preact-signals": "1.0.3",
		"astro": "7.0.2",
		"astro-expressive-code": "0.44.0",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"svelte": "5.56.4",
		"typescript": "6.0.3"
	},
	"devDependencies": {
		"@11ty/eleventy-fetch": "5.1.2",
		"@astrojs/check": "0.9.9",
		"@biomejs/biome": "2.5.1",
		"@clack/prompts": "1.6.0",
		"@expressive-code/plugin-line-numbers": "0.44.0",
		"@notionhq/client": "5.22.0",
		"@types/markdown-it": "14.1.2",
		"@types/sanitize-html": "2.16.1",
		"execa": "9.6.1",
		"fs-extra": "11.3.5",
		"linkedom": "0.18.12",
		"markdown-it": "14.2.0",
		"postcss-custom-media": "12.0.1",
		"postcss-html": "1.8.1",
		"postcss-import": "16.1.1",
		"postcss-values-parser": "8.0.0",
		"sanitize-html": "2.17.5",
		"stylelint": "17.14.0",
		"stylelint-config-html": "1.1.0",
		"stylelint-plugin-logical-css": "2.1.0",
		"temporal-polyfill-lite": "0.4.1",
		"vitest": "4.1.9"
	}
}
