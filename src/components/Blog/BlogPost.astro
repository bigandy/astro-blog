---
import BackArrow from "@components/Global/BackArrow.astro";
import BlogContent from "@components/Blog/BlogContent.astro";
import BlogPostHeader from "@components/Blog/BlogPostHeader.astro";
import { blogHomeUrl } from "@components/Nav/pages";

const {
  post,
  showBackLink = true,
  showDate = true,
  hasTranslation,
} = Astro.props;

const { Content } = await post.render();

const backTitle = Astro.currentLocale ? "Retour au blog" : "Back to blog";
---

<article class="content post layout-inner">
  <BlogPostHeader
    date={showDate && post.data.date}
    title={post.data.title}
    isPreview={false}
    slug={post.slug}
  />

  <BlogContent>
    {!hasTranslation && Astro.currentLocale && <p>No Translation Available.</p>}
    <Content />
  </BlogContent>

  {showBackLink && <BackArrow url={blogHomeUrl} title={backTitle} />}
</article>

<style>
  .content {
    margin-block-end: 8rem;
  }

  .content :global(main > * + *) {
    margin-block-start: 1rem;
  }
</style>
