---

import HeaderNav from "@components/Nav/HeaderNav.astro";

const { hidePhoto = false } = Astro.props;

const homeUrl = Astro.currentLocale === "fr" ? `/${Astro.currentLocale}` : "/";
---

<header class="layout">
    <div class="layout-inner">
        <h1>
            <a href={homeUrl}> Andrew JD Hudson </a>
        </h1>
        <HeaderNav hidePhoto={hidePhoto} />
    </div>

</header>

<style>
    header {
        display: grid;
        grid-template-columns: subgrid;
        grid-column: page;
    }

    .layout-inner {
        padding-block-start: calc(var(--column-gap-size) * 3);
        grid-template-columns: subgrid;
        grid-column: center;
        grid-row: 1;
    }

    h1 {
        margin-block-end: 0.5rem;
        font-size: 1.5rem;

        a {
            vertical-align: -1px;
            font-weight: bold;
            display: inline-flex;

            &:hover {
                text-decoration: none;
            }
        }
    }
</style>
