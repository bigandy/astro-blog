---
import ArchivePageLayout from "@layouts/ArchivePageLayout.astro";
import type { CollectionEntry } from "astro:content";
import { getAllPosts } from "@components/Blog/utils/getAllPosts";
import type { GetStaticPaths } from "astro";

interface Props {
	page: {
		currentPage: number;
		data: CollectionEntry<"weeknotes">;
        url: {
            current: string;
        }
	};
}

const { page } = Astro.props;

export const getStaticPaths = (async ({ paginate }) => {
	const allPosts = await getAllPosts("weeknotes");

	// Return a paginated collection of paths for all posts
	return paginate(allPosts, { pageSize: 10 });
}) satisfies GetStaticPaths;

---

<ArchivePageLayout page={page} />
