---
import BlogPostPreview from "@components/Blog/BlogPostPreview.astro";
import { getAllPosts } from "@components/Blog/utils/getAllPosts";
import ArchiveNav from "@components/Global/ArchiveNav.astro";
import DefaultLayout from "@layouts/DefaultLayout.astro";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";

export const getStaticPaths = (async ({ paginate }) => {
	const allPosts = await getAllPosts("weeknotes", "fr");

	// Return a paginated collection of paths for all posts
	return paginate(allPosts, { pageSize: 10 });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page } = Astro.props;
const prevText = "articles plus récents";
const nextText = "articles plus anciens";
---

<DefaultLayout title={`les Weeknotes Archive Page ${page.currentPage}`}>
  <div class="top-nav">
    <ArchiveNav page={page} prevText={prevText} nextText={nextText} />
  </div>

  {page.data.map((p, postIndex) => <BlogPostPreview post={p} collection='weeknotes-fr' postIndex={postIndex}/>)}

  <ArchiveNav page={page} />
</DefaultLayout>
<style>
  .top-nav {
    margin-block-end: 2em;
  }
</style>
