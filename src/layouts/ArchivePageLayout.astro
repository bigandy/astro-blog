---
import BlogPostPreview from "@components/Blog/BlogPostPreview.astro";
import ArchiveNav from "@components/Global/ArchiveNav.astro";
import DefaultLayout from "@layouts/DefaultLayout.astro";
import type { CollectionEntry } from "astro:content";

const isBlog = Astro.props.page.url.current.includes('blog');

interface Props {
	page: {
		currentPage: number;
		data: CollectionEntry<"weeknotes" | "blog">;
        url: {
            current: string;
        }
	};
}

const { page } = Astro.props;
const title = `${isBlog ? "Blog" : "Weeknote"} Archive Page ${page.currentPage}`;
---

<DefaultLayout title={title}>
    <div class="top-nav">
        <ArchiveNav page={page} />
    </div>

    {
        page.data.map((post) => <BlogPostPreview post={post} postIndex={post.postIndex} collection={isBlog ? 'blog' : 'weeknotes' } /> )
    }

    <ArchiveNav page={page} />
</DefaultLayout>
<style>
    .top-nav {
        margin-block-end: 2em;
    }
</style>